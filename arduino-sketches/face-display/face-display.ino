// ---------- face dispatch table ----------
const uint16_t* FACES[FACE_COUNT] = {
  faceIdleBitmap,   // FACE_IDLE
  faceSmugBitmap,   // FACE_SMUG
  faceSadBitmap,    // FACE_SAD
  faceWinBitmap,    // FACE_WIN
};

// fallback tints used when a face has no bitmap yet.
const uint16_t FACE_TINT[FACE_COUNT] = {
  0xffff,  // IDLE - white
  0xffe0,  // SMUG - yellow
  0x001f,  // SAD  - blue
  0x07e0,  // WIN  - green
};

uint8_t currentFace = 255;

void drawFace(uint8_t id) {
  if (id >= FACE_COUNT) return;
  if (id == currentFace) return;
  currentFace = id;

  const uint16_t* bmp = FACES[id];
  if (bmp == nullptr) {
    matrix.fillScreen(FACE_TINT[id]);
  } else {
    for (int16_t y = 0; y < 32; y++) {
      for (int16_t x = 0; x < 32; x++) {
        uint16_t c = pgm_read_word(&bmp[y * 32 + x]);
        matrix.drawPixel(x, y, c);
      }
    }
  }
  matrix.show();
}

uint8_t commandToFace(char c) {
  switch (c) {
    case 'I': case 'i': return FACE_IDLE;
    case 'C': case 'c': return FACE_SMUG;
    case 'S': case 's': return FACE_SAD;
    case 'W': case 'w': return FACE_WIN;
    default:            return 255;
  }
}

// ---------- arduino lifecycle ----------
void setup() {
  Serial.begin(115200);

  ProtomatterStatus status = matrix.begin();
  if (status != PROTOMATTER_OK) {
    pinMode(LED_BUILTIN, OUTPUT);
    while (true) {
      digitalWrite(LED_BUILTIN, HIGH); delay(100);
      digitalWrite(LED_BUILTIN, LOW);  delay(100);
    }
  }

  matrix.fillScreen(0x0000);
  drawFace(FACE_IDLE);
  Serial.println("face-display ready");
}

void loop() {
  while (Serial.available()) {
    int b = Serial.read();
    if (b < 0) break;
    if (b == '\n' || b == '\r' || b == ' ') continue;

    uint8_t f = commandToFace((char)b);
    if (f != 255) drawFace(f);
  }
}
