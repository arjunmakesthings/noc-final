/*
  face-display: 32x32 RGB matrix that swaps facial expressions over serial.
  target board: Arduino Zero (Native USB Port preferred).

  serial protocol (115200 baud, newline-terminated, case-insensitive):
    I  -> idle
    C  -> smug
    S  -> sad
    W  -> win
  unknown bytes are ignored. on boot the matrix shows IDLE.

  bitmaps:
    each face = uint16_t[1024] PROGMEM array (32x32 RGB565, row-major).
    a face whose slot is nullptr falls back to a solid tint colour so the
    serial protocol can be verified before the real art exists.
*/

#include <Adafruit_Protomatter.h>

// ---------- matrix wiring (RGB Matrix Shield default) ----------
uint8_t rgbPins[]  = {2, 3, 4, 5, 6, 7};
uint8_t addrPins[] = {A0, A1, A2, A3};
uint8_t clockPin   = 8;
uint8_t latchPin   = 10;
uint8_t oePin      = 9;

Adafruit_Protomatter matrix(
  32, 4, 1, rgbPins, 4, addrPins,
  clockPin, latchPin, oePin, false);

// ---------- face slots ----------
enum FaceId : uint8_t {
  FACE_IDLE = 0,
  FACE_SMUG,
  FACE_SAD,
  FACE_WIN,
  FACE_COUNT
};

